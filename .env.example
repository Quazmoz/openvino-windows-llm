# OpenVINO Windows LLM - Environment Configuration
# Copy this file to .env and adjust as needed:  copy .env.example .env

# --- Server ---
OV_LLM_HOST=127.0.0.1
OV_LLM_PORT=8000

# Default inference device: CPU | GPU | NPU | AUTO
OV_LLM_DEVICE=CPU

# Default model id to load on startup (must exist in models.json).
# Leave blank to start without auto-loading a model.
OV_LLM_MODEL=tinyllama-1.1b-chat

# Model catalog and converted-model locations.
OV_LLM_MODELS_FILE=models.json
OV_LLM_MODELS_DIR=models/openvino

# --- Optional API key enforcement ---
# When set, all /v1/* requests must send: Authorization: Bearer <key>
# Leave blank for local-only, unauthenticated use.
OV_LLM_API_KEY=

# --- Mock mode (no OpenVINO required) ---
# Set to 1 to force the built-in mock engine, e.g. to test the web UI on a
# machine without OpenVINO (macOS / Linux dev box). On non-Windows hosts where
# openvino-genai is not installed, mock mode is enabled automatically.
OV_LLM_MOCK=

# --- Hugging Face token (only needed to convert gated models, e.g. Llama) ---
# Get a token at https://huggingface.co/settings/tokens and accept the model license.
HF_TOKEN=

# --- Enterprise TLS (only if Hugging Face downloads fail on a managed network) ---
# REQUESTS_CA_BUNDLE=C:\path\to\company-root-ca.pem
# SSL_CERT_FILE=C:\path\to\company-root-ca.pem
