# --- Local models (large, never commit) ---
# Ignore converted-model contents but keep the directory placeholder tracked.
models/openvino/*
!models/openvino/.gitkeep

# --- OpenVINO / model caches ---
.ov_cache/
ov_cache/
*.blob

# --- Hugging Face cache ---
.cache/
cache/

# --- Environment files (secrets) ---
.env
*.env
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
*.egg
.venv/
venv/
env/
.python-version

# --- Tooling caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# --- Logs / scratch ---
*.log
diagnostics-*.json
benchmark/results/
certification/results/

# --- Release / packaging outputs (generated by scripts/build_release.ps1) ---
# Keeping these ignored lets the release pipeline run idempotently: its
# clean-tree gate must not trip over its own generated output on a re-run.
/build/
/dist/
/artifacts/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- Temp / local run artifacts ---
.codex-run/
.tmp/

# --- OS ---
.DS_Store
Thumbs.db

# --- MemoryOps local credentials and private generated config ---
.memoryops.local.json
.memoryops/
.mcp.json
.vscode/mcp.json
mcp.json
mcp.*.json

# --- Dependency install marker (auto-created by start_server.bat) ---
.deps_installed
